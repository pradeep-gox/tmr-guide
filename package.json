{
  "name": "tmr-guide",
  "version": "0.1.0",
  "description": "Clippy-style AI guide SDK for TMR frontends",
  "files": [
    "dist"
  ],
  "main": "dist/tmr-guide.esm.js",
  "module": "dist/tmr-guide.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tmr-guide.esm.js",
      "require": "./dist/tmr-guide.esm.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "format": "oxfmt"
  },
  "devDependencies": {
    "oxfmt": "^0.41.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^3.9.1"
  }
}
